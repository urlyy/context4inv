    {
      "phase": 2,
      "name": "ACSL Frama-C Conversion",
      "description": "Converts raw benchmarks to Frama-C-compatible format via external fmagent toolchain: renames main() to foo(), transforms Unicode ACSL (∀, =>) to \\forall / ==> format, and generates _frama.c files (226 exist; multivar_1-1 lacks one), _handle_assert_infilled.c, _handle_assert_marked.c, and .pickle artifacts.",
      "modules": [],
      "depends_on_phases": [1]
    },
    {
      "phase": 3,
      "name": "ESBMC/IBMC Conversion",
      "description": "Converts raw .c files to ESBMC-compatible _ibmc.c format: replaces ACSL assertions with __VERIFIER_assert calls, converts ∀ quantifiers to __forall() calls, transforms uninitialized int declarations to nondet_int() assignments, and adds __VERIFIER_assume calls. Entry point remains main() (NOT renamed to foo()). All 227 _ibmc.c files exist.",
      "modules": [
        {
          "name": "ibmc_converter",
          "source_files": ["convert_to_ibmc.py"]
        }
      ],
      "depends_on_phases": [1]
    },
    {
      "phase": 4,
      "name": "Verification and Analysis Utilities",
      "description": "Provides auxiliary tools for nested loop detection (check_nested_loops.py), assume-to-requires conversion (convert_assume.py, brittle: hardcoded path), benchmark discovery from test.csv (find_targets.py), JSON data dumping (dump_code.py), and file listing utilities (dump.sh) for the benchmark suite.",
      "modules": [
        {
          "name": "analysis_utilities",
          "source_files": [
            "check_nested_loops.py",
            "convert_assume.py",
            "find_targets.py",
            "dump_code.py",
            "dump.sh"
          ]
        }
      ],
      "depends_on_phases": [1, 2, 3]
    }
  ]
